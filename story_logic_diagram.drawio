    <!-- ================================================ -->
    <!-- LAYER 5: Application Domains                     -->
    <!-- ================================================ -->

    <!-- Applications Header -->
    <mxCell id="500" value="&lt;b&gt;跨领域应用拓展 — 回扣故事起点的五大物理系统&lt;/b&gt;&lt;br&gt;&lt;i&gt;Application Domains: Closing the Loop Across All Five Physical Systems&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#004D40;fontColor=#ffffff;strokeColor=#00695C;fontSize=12;arcSize=8;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="327" y="1920" width="1000" height="70" as="geometry" />
    </mxCell>

    <!-- Application 1: 5G/6G -->
    <mxCell id="501" value="&lt;b&gt;① 5G/6G 无线通信&lt;/b&gt;&lt;br&gt;&lt;br&gt;痛点：标准更迭频繁，设计周期长&lt;br&gt;方案：需求直接输入 → 自动生成最优方案 + 3GPP 草案&lt;br&gt;&lt;b&gt;价值：根本压缩设计周期，使能快速标准化&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#ffffff;strokeColor=#004D40;fontSize=10;arcSize=5;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
      <mxGeometry x="107" y="2060" width="280" height="120" as="geometry" />
    </mxCell>

    <!-- Application 2: Optical -->
    <mxCell id="502" value="&lt;b&gt;② 相干光通信（400G/800G）&lt;/b&gt;&lt;br&gt;&lt;br&gt;痛点：非高斯噪声难以建模&lt;br&gt;方案：非参数 PDF 编码器天然适配&lt;br&gt;&lt;b&gt;价值：突破非高斯信道 ECC 性能瓶颈&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#ffffff;strokeColor=#004D40;fontSize=10;arcSize=5;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
      <mxGeometry x="407" y="2060" width="280" height="120" as="geometry" />
    </mxCell>

    <!-- Application 3: Flash -->
    <mxCell id="503" value="&lt;b&gt;③ NAND Flash 存储&lt;/b&gt;&lt;br&gt;&lt;br&gt;痛点：磨损噪声分布非平稳&lt;br&gt;方案：逐单元 SNR 序列精确建模&lt;br&gt;&lt;b&gt;价值：定制化 ECC 延长 QLC Flash 寿命&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#ffffff;strokeColor=#004D40;fontSize=10;arcSize=5;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
      <mxGeometry x="707" y="2060" width="280" height="120" as="geometry" />
    </mxCell>

    <!-- Application 4: Quantum -->
    <mxCell id="504" value="&lt;b&gt;④ 量子纠错（QECC）&lt;/b&gt;&lt;br&gt;&lt;br&gt;痛点：量子码设计完全无 EDA 工具&lt;br&gt;方案：通用三元组适配 Pauli 信道&lt;br&gt;&lt;b&gt;价值：开辟量子 EDA 新方向&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#ffffff;strokeColor=#004D40;fontSize=10;arcSize=5;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
      <mxGeometry x="1007" y="2060" width="280" height="120" as="geometry" />
    </mxCell>

    <!-- Application 5: Memristor -->
    <mxCell id="505" value="&lt;b&gt;⑤ 忆阻器存算一体&lt;/b&gt;&lt;br&gt;&lt;br&gt;痛点：无任何成熟 ECC 工具，无信道先验&lt;br&gt;方案：仅凭实测样本（核密度估计 p(x)）完成设计&lt;br&gt;&lt;b&gt;价值：赋能下一代存算一体芯片可靠性&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#ffffff;strokeColor=#004D40;fontSize=10;arcSize=5;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
      <mxGeometry x="1307" y="2060" width="280" height="120" as="geometry" />
    </mxCell>

    <!-- Arrows: Applications Header → Each App -->
    <mxCell id="511" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.13;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#26A69A;endArrow=block;endFill=1;strokeWidth=1.5;" edge="1" source="500" target="501" parent="1">
